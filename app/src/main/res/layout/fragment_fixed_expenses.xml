<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fixed Expenses"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/fixed_edit_mode_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Editing selected fixed expense"
            android:textStyle="bold"
            android:visibility="gone" />

        <EditText
            android:id="@+id/fixed_name_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Name"
            android:inputType="text" />

        <Spinner
            android:id="@+id/fixed_category_spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <EditText
            android:id="@+id/fixed_amount_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Amount"
            android:inputType="numberDecimal" />

        <EditText
            android:id="@+id/fixed_due_date_input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Due date (1-31)"
            android:inputType="number" />

        <CheckBox
            android:id="@+id/fixed_recurring_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Recurring" />

        <Button
            android:id="@+id/fixed_save_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Save Fixed Expense" />

        <Button
            android:id="@+id/fixed_cancel_edit_button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Cancel Edit"
            android:visibility="gone" />

        <TextView
            android:id="@+id/fixed_empty_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="No fixed expenses yet"
            android:visibility="gone" />

        <ListView
            android:id="@+id/fixed_list"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Tip: tap item to edit, long-press to delete"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
